{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/customer/:path*", "destination": "/customer/:path*" },
    { "source": "/vendor/:path*", "destination": "/vendor/:path*" },
    { "source": "/admin/:path*", "destination": "/admin/:path*" },
    { "source": "/:path*", "destination": "/index.html" }
  ],
  "redirects": [
    { "source": "/admin", "destination": "/admin/dashboard.html", "permanent": true },
    { "source": "/vendor", "destination": "/vendor/login.html", "permanent": true },
    { "source": "/customer", "destination": "/customer/dashboard.html", "permanent": true }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
